{
  "brand_id": "sony",
  "display_name": "Sony",
  "version": 1,
  "exiftool_make_match": ["SONY"],
  "tested_bodies": ["ILCE-6700"],

  "tz_setting_instructions": {
    "ILCE-6700": [
      "Press MENU and open the Setup tab.",
      "'Area/Date/Time Setup' → 'Area Setting': pick the destination region.",
      "'Area/Date/Time Setup' → 'Date/Time Setup': verify wall-clock date and time.",
      "'Area/Date/Time Setup' → 'Daylight Savings Time': toggle as appropriate for the destination."
    ],
    "_default": [
      "Open the Setup menu (gear icon on most Sony bodies).",
      "Find 'Area/Date/Time Setup' (older bodies: 'Date/Time/Area').",
      "Set the Area first (the timezone) — the camera adjusts the displayed clock when Area changes.",
      "Verify the wall-clock date and time are right for the destination."
    ]
  },

  "focus_mode": {
    "exif_tag": "FocusMode",
    "exif_tag_alternatives": ["FocusModeSetting"],
    "mapping": {
      "manual": ["Manual", "MF", "DMF"],
      "single": ["AF-S", "Single-shot AF", "AFS"],
      "continuous": ["AF-C", "Continuous AF", "AFC", "AF-A"]
    },
    "default": "unknown"
  },

  "af_area_mode": {
    "exif_tag": "AFAreaMode",
    "exif_tag_alternatives": ["AFAreaModeSetting", "FocusAreaMode"],
    "mapping": {
      "single_point": ["Spot", "Flexible Spot", "Spot S", "Spot M", "Spot L"],
      "zone": ["Zone", "Expand Spot", "Expand Flexible Spot"],
      "wide": ["Wide", "Full"],
      "face_eye": ["Face Detection", "Face/Eye Priority AF", "Face Priority"],
      "subject_tracking": ["Tracking", "Lock-on AF"]
    },
    "default": "unknown"
  },

  "subject_detection": {
    "exif_tag": "SubjectDetection",
    "exif_tag_alternatives": ["AFTracking", "SubjectRecognitionAF"],
    "mapping": {
      "none": ["Off", "None"],
      "human": ["Human", "Face", "Eye"],
      "animal": ["Animal", "Animal Eye", "Insect"],
      "bird": ["Bird", "Bird Eye"],
      "vehicle": ["Car", "Train", "Airplane", "Vehicle"]
    },
    "default": "none"
  },

  "drive_mode": {
    "exif_tag": "DriveMode",
    "exif_tag_alternatives": ["ReleaseMode"],
    "mapping": {
      "single": ["Single Frame", "Single Shooting", "Single"],
      "burst_low": ["Continuous Lo", "Continuous Low", "Cont. Lo"],
      "burst_high": ["Continuous Hi", "Continuous Hi+", "Continuous High", "Cont. Hi"],
      "self_timer": ["Self-timer", "Self Timer"]
    },
    "default": "single"
  },

  "photo_style": {
    "exif_tag": "CreativeLook",
    "exif_tag_alternatives": ["CreativeStyle"],
    "mapping": {
      "portrait": ["Portrait", "PT"],
      "scenery": ["Landscape", "LS"],
      "natural": ["Neutral", "NT"],
      "vivid": ["Vivid", "VV", "VV2", "Deep"],
      "monochrome": ["Black & White", "BW", "Sepia", "SE"],
      "standard": ["Standard", "ST", "Clear", "Light"],
      "unknown": ["Off", "None"]
    },
    "default": "unknown"
  },

  "bracket_detection": {
    "focus_bracket": {
      "exif_tag": "FocusBracketingShotNumber",
      "is_active_when": "value > 0"
    },
    "exposure_bracket": {
      "exif_tag": "DriveMode",
      "active_values": [
        "Continuous Bracketing",
        "Single Bracketing",
        "Bracketing",
        "AE Bracketing"
      ]
    }
  },

  "af_point": {
    "kind": "sony_focus_location",
    "location_tag": "FocusLocation",
    "frame_size_tag": "FocusFrameSize",
    "default_box": 0.08
  },

  "lens_normalization": {
    "lens_model_tag": "LensModel",
    "lens_model_tag_alternatives": ["LensType", "LensID"],
    "lens_id_tag": "LensID",
    "aliases": [
      {
        "canonical": "Sony E 70-350 G",
        "matches": ["E 70-350mm F4.5-6.3 G OSS", "SEL70350G"]
      },
      {
        "canonical": "Sony E 16-55 G",
        "matches": ["E 16-55mm F2.8 G", "SEL1655G"]
      },
      {
        "canonical": "Sony E 11mm f/1.8",
        "matches": ["E 11mm F1.8", "SEL11F18"]
      },
      {
        "canonical": "Sony E 15mm f/1.4 G",
        "matches": ["E 15mm F1.4 G", "SEL15F14G"]
      },
      {
        "canonical": "Sigma 30mm f/1.4 DC DN",
        "matches": ["30mm F1.4 DC DN"]
      },
      {
        "canonical": "Sigma 56mm f/1.4 DC DN",
        "matches": ["56mm F1.4 DC DN"]
      },
      {
        "canonical": "Tamron 17-70 f/2.8",
        "matches": ["17-70mm F/2.8", "Tamron 17-70"]
      }
    ]
  }
}
